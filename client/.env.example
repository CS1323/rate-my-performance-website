# Frontend Environment Configuration
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is listed in .gitignore.
# All variables must be prefixed with VITE_ to be exposed to the browser bundle.

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
# Base URL for backend API calls.
# Development default: http://localhost:5001
# Production:          https://api.ratemyperformancecfu.com
VITE_API_BASE_URL=http://localhost:5001

# ─────────────────────────────────────────────
# Error Tracking
# ─────────────────────────────────────────────
# Sentry DSN for frontend error capture.
# Leave blank to disable Sentry (safe for local development).
# Obtain from: https://sentry.io/
VITE_SENTRY_DSN=

# ─────────────────────────────────────────────
# Analytics
# ─────────────────────────────────────────────
# Google Analytics 4 Measurement ID.
# Leave blank to disable GA tracking entirely.
# Analytics are also suppressed automatically on localhost regardless of this value.
# Obtain from: https://analytics.google.com/
#
# Note: GA4 city/region data may reflect Vercel edge-server locations
# rather than actual visitor locations due to Vercel's CDN architecture.
# Country-level data is generally reliable; city-level is approximate.
VITE_GA_ID=
