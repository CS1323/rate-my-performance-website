{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "cross-env NODE_OPTIONS=\"--import ./instrument.js\" nodemon --exec node server.js",
    "dev:test": "dotenv -e .env.test nodemon server.js",
    "start": "NODE_OPTIONS=\"--import ./instrument.js\" node server.js",
    "build": "npm run prisma:migrate",
    "prisma:migrate": "npx prisma@6.19.2 migrate deploy",
    "prisma_migrate:test": "dotenv -e .env.test npx prisma@6.19.2 migrate deploy",
    "seed:db": "dotenv -e .env.production node prisma/seed.js",
    "seed:test": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@google/generative-ai": "^0.3.0",
    "@prisma/client": "6.19.2",
    "@sentry/node": "^10.46.0",
    "@sentry/react": "^10.46.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "jsdom": "^29.0.1",
    "prisma": "6.19.2",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
