# Backend Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit .env — it is listed in .gitignore.

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────

PORT=5001

# Node environment: development | test | production
# - development: verbose logging, file watching (nodemon), Sentry disabled by default
# - test: test database, seeding via seed:test script
# - production: minimal logging, static server, Sentry required
NODE_ENV=development

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# Local PostgreSQL example:
#   postgresql://postgres:password@localhost:5432/rate_my_performance
# Neon (cloud) example:
#   postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/rate_my_performance

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Development: http://localhost:5173
# Production:  https://ratemyperformancecfu.com,https://www.ratemyperformancecfu.com
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────
# Content Moderation
# ─────────────────────────────────────────────
# Google Gemini API key — used for LLM-assisted comment moderation.
# Obtain from: https://ai.google.dev/
# Leave blank to disable AI moderation (keyword-only fallback will still run).
GEMINI_API_KEY=

# ─────────────────────────────────────────────
# Error Tracking
# ─────────────────────────────────────────────
# Sentry DSN for server-side error capture.
# Leave blank to disable Sentry (safe for local development).
# Obtain from: https://sentry.io/
SENTRY_DSN=

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
# Winston log level: debug | info | warn | error
# Recommended: debug in development, info in production.
LOG_LEVEL=debug
